rules_version = '2';

// V49 Checkpoint A — Patch d'urgence Firestore Rules versionné dans le repo.
//
// Reproduit à l'identique le patch déployé manuellement en console Firebase
// le 2026-05-01 19:54 (avant l'audit V48-BIS qui a constaté l'absence de
// firestore.rules dans le repo).
//
// Ce fichier est la BASELINE. Le Checkpoint B V49 enrichira avec RBAC
// (rôles client / partner / admin via custom claims) — ce fichier sera
// alors étendu avec helpers et matchers granulaires.
//
// Référencé par firebase.json → "firestore": { "rules": "firestore.rules" }.
// Déploiement : firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {
    // 📦 Catalogue public (lecture libre) — produits + paramètres taux
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /admin_params/{paramId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 🚫 Fallback : tout le reste exige authentification.
    // V49 Checkpoint B remplacera par du RBAC granulaire.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
