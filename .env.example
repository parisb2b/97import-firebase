# Template de configuration 97import — copier en .env.production (qui est gitignored).
# V49 Checkpoint D — remplace l'ancien .env.production qui etait tracked en git.
# V53-PRODUCTION-READINESS — ajout VITE_APP_ENV / VITE_APP_VERSION + Firebase Project ID
#
# IMPORTANT : remplir les valeurs avec les vraies cles depuis :
#   - Firebase Console > Settings > General > Your apps (Web app)
#   - DeepL Account > API Keys
#   - Resend > API Keys
#   - exchangerate-api.com (si compte) / Frankfurter (gratuit, sans cle)
#
# Une fois rempli localement, ne JAMAIS commit le fichier (.gitignore le bloque).
# En prod (Vercel), stocker ces variables en Environment Variables UI.

# Firebase (cles publiques par design Firebase — bundle client)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=importok-6ef77
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Services externes (cles secretes — exposees en bundle client par Vite,
# considerer migration vers Vercel Functions /api/* en V50+ si besoin de
# vraie protection. APIs gratuites OK en mode actuel.)
VITE_DEEPL_KEY=
VITE_RESEND_KEY=
VITE_EXCHANGE_KEY=

# App metadata
VITE_APP_ENV=development
VITE_APP_VERSION=v0.43.3
